# Production environment for Hetzner deployment
# Copy to .env.production and fill in values

# Database (SQLite file in persistent volume)
DATABASE_URL=file:/app/data/skissify.db

# Auth
NEXTAUTH_URL=https://skissify.conzeon.dev
NEXTAUTH_SECRET=  # Generate with: openssl rand -base64 32

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional — remove GitHub provider in auth.ts if not used)
GITHUB_ID=
GITHUB_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# App
NEXT_PUBLIC_APP_URL=https://skissify.conzeon.dev
